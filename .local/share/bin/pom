#!/usr/bin/env python
from alive_progress import alive_it
import time
import os
import notify2
import argparse
import logging

LOG_PATH = os.environ['XDG_CACHE_HOME']

logging.basicConfig(
        level=logging.INFO,
        filename=f'{LOG_PATH}/pom/{time.strftime("%d.%m.%y")}.log',
        filemode='a',
        format="%(asctime)s: %(message)s",
        datefmt='%H:%M:%S'
        )

notify2.init('pom')

def timeup_notification():
    title = 'Time Up'
    notice = notify2.Notification(title)
    notice.set_urgency(notify2.URGENCY_CRITICAL)
    notice.show()

def get_args():
    parser = argparse.ArgumentParser()
    parser.add_argument('-t', '--time', type=str, help='time to wait')
    return parser.parse_args()

def go_to_sleep(wait_time):
    bar = alive_it(range(60 * wait_time))

    for _ in bar:
        try:
            time.sleep(1)
        except KeyboardInterrupt:
            bar.pause()
            bar.text('Press any key to continue .....')
            input()

    logging.info(f'Finished pom of {wait_time} minutes')
    timeup_notification()

def main(): 
    args = get_args()
    if not args.time:
        print('Please supply time to wait')
        return
    
    go_to_sleep(int(args.time))


if __name__ == "__main__":
    main()
